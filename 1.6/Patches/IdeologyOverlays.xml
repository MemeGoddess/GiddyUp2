<?xml version="1.0" encoding="utf-8" ?>
<Patch>

	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Ideology</li>
		</mods>
		<match Class="PatchOperationSequence">
			<success>Always</success>
			<operations>
				<li Class="PatchOperationAdd">
					<success>Always</success>
					<xpath>Defs/ThingDef[defName="Dryad_Clawer"][not(comps)]</xpath>
					<value>
						<comps />
					</value>
				</li>
				<li Class="PatchOperationAdd">
					<xpath>Defs/ThingDef[defName="Dryad_Clawer"]/comps</xpath>
					<value>
						<li Class="GiddyUp.CompProperties_Overlay">
							<overlayFront>
								<graphicDataDefault>
									<texPath>Things/Pawn/Dryad_Clawer_south</texPath>
									<graphicClass>Graphic_Single</graphicClass>
									<drawSize>1.5</drawSize>
									<drawRotated>false</drawRotated>
								</graphicDataDefault>
							</overlayFront>
						</li>
					</value>
				</li>
			</operations>
		</match>
	</Operation>
</Patch>
